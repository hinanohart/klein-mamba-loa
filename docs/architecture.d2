vf: "Velocity Field\nflow/velocity" {style: {fill: "#dcfce7"; font-color: "#065f46"; stroke: "#10b981"; bold: true}}
loss: "④ SPF Loss PGC-DFM\nL_fm + L_ortho + L_cond" {style: {fill: "#0ea5e9"; font-color: "#ffffff"; stroke: "#0369a1"; bold: true; font-size: 18}}
gate: "⑤ Runtime Gate\nGREEN / YELLOW / RED" {style: {fill: "#0ea5e9"; font-color: "#ffffff"; stroke: "#0369a1"; bold: true; font-size: 18}}
serve: "⑥ Serving Layer\ncommercial consent gate" {shape: oval; style: {fill: "#6366f1"; font-color: "#ffffff"; stroke: "#4338ca"; bold: true; font-size: 18}}

mcp -> persona.pg: "② build basis"
persona.pg -> persona.lp: "blend"
